{
  "name": "Application",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "title": "Company Name"
    },
    "job_title": {
      "type": "string",
      "title": "Job Title"
    },
    "description": {
      "type": "string",
      "title": "Job Description / Notes"
    },
    "job_url": {
      "type": "string",
      "title": "Job Posting URL"
    },
    "status": {
      "type": "string",
      "enum": [
        "wishlist",
        "applied",
        "interviewing",
        "offer",
        "closed"
      ],
      "default": "wishlist",
      "title": "Status"
    },
    "interview_datetime": {
      "type": "string",
      "format": "date-time",
      "title": "Interview Date & Time"
    },
    "date_applied": {
      "type": "string",
      "format": "date",
      "title": "Date Applied"
    },
    "archived": {
      "type": "boolean",
      "default": false,
      "title": "Archived"
    },
    "resume_url": {
      "type": "string",
      "title": "Resume File URL"
    },
    "resume_name": {
      "type": "string",
      "title": "Resume File Name"
    },
    "interview_prep": {
      "type": "string",
      "title": "Interview Prep Notes"
    },
    "activity_log": {
      "type": "array",
      "title": "Activity Log",
      "items": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "from": {
            "type": "string",
            "title": "Previous Status"
          },
          "entered_at": {
            "type": "string",
            "format": "date-time",
            "title": "Entered At"
          }
        }
      }
    }
  },
  "required": [
    "company_name",
    "job_title"
  ]
}
